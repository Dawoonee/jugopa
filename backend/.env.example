# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True

# Anthropic (news 요약용) — https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# 공공데이터포털 금융위원회 주식시세정보 서비스 키 (Decoding 키 권장)
# https://www.data.go.kr 에서 발급
FINANCIAL_API_KEY=your-service-key

# GMS (챗봇용 LLM, OpenAI 호환 API) — GMS 콘솔에서 발급/확인
# GMS_BASE_URL 은 /chat/completions 앞부분까지 (예: https://gms.example.com/v1)
GMS_API_KEY=your-gms-api-key
GMS_BASE_URL=https://gms.example.com/v1
GMS_MODEL=gpt-5-nano
